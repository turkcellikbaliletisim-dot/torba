# TORBAA Environment Configuration Template
NODE_ENV=production
PORT=3000

# PostgreSQL Connection
POSTGRES_USER=torbaa_user
POSTGRES_PASSWORD=replace_with_secure_postgres_password_in_prod
POSTGRES_DB=torbaa_db
DATABASE_URL=postgres://torbaa_user:replace_with_secure_postgres_password_in_prod@localhost:5432/torbaa_db

# Cryptographic & Auth Secrets
JWT_SECRET=replace_with_secure_jwt_secret_key_minimum_32_characters
QR_SECRET_KEY=replace_with_secure_qr_secret_key_minimum_32_characters

# Redis & Dragonfly
REDIS_URL=redis://localhost:6379

# SMS Gateway Credentials (Netgsm / Twilio)
SMS_PROVIDER=DEV_MOCK
NETGSM_USER=netgsm_user_code
NETGSM_PASS=netgsm_password
NETGSM_HEADER=TORBAA

# Payment Gateway Credentials (Iyzico / Craftgate)
PAYMENT_API_KEY=replace_with_payment_api_key
PAYMENT_SECRET_KEY=replace_with_payment_secret_key
